# Infra
APP_NAME=nexus
VPS_HOST=203.0.113.10
DEPLOY_USER=deploy
PROJECT_DIR=/srv/app
API_DOMAIN=api.example.com
NGINX_TEMPLATE=default.http.conf.template
# opciones: default.http.conf.template | default.https.conf.template | default.cloudflare-origin.conf.template
TZ=America/Argentina/Buenos_Aires

# Backend
BACKEND_CONTEXT=./backend
BACKEND_DOCKERFILE=Dockerfile
BACKEND_PORT=3000
TEGOLA_MAP=peru
FRONTEND_ORIGIN=https://your-frontend.vercel.app
FRONTEND_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
REQUEST_TIMEOUT_MS=5000
UPSTREAM_RETRIES=2
LOG_LEVEL=info
JWT_SECRET=replace_with_long_random_secret

# PostgreSQL / PostGIS
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=replace_with_long_random_password
DATABASE_URL=postgresql://appuser:replace_with_long_random_password@postgres:5432/appdb

# Redis
REDIS_PASSWORD=replace_with_long_random_password
REDIS_URL=redis://:replace_with_long_random_password@redis:6379

# Backups
BACKUP_DIR=/srv/backups
BACKUP_RETENTION_DAYS=7
