# Infra
APP_NAME=nexus
VPS_HOST=203.0.113.10
DEPLOY_USER=deploy
PROJECT_DIR=/srv/app
API_DOMAIN=api.example.com
NGINX_TEMPLATE=default.http.conf.template
# opciones: default.http.conf.template | default.https.conf.template | default.cloudflare-origin.conf.template
TZ=America/Argentina/Buenos_Aires

# Backend
BACKEND_CONTEXT=./apps/backend
BACKEND_DOCKERFILE=Dockerfile
BACKEND_PORT=3000
TEGOLA_MAP=peru
FRONTEND_ORIGIN=https://your-frontend.vercel.app
FRONTEND_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
REQUEST_TIMEOUT_MS=5000
UPSTREAM_RETRIES=2
LOG_LEVEL=info
RATE_LIMIT_MAX_PER_MINUTE=500000
RATE_LIMIT_FORMS_PER_MINUTE=1200
RATE_LIMIT_FORMS_IP_PER_MINUTE=12000
RATE_LIMIT_FORMS_WINDOW_SEC=60
RATE_LIMIT_AGENTS_LOCATION_PER_MINUTE=12000
RATE_LIMIT_AGENTS_LIVE_PER_MINUTE=3000
RATE_LIMIT_AGENTS_STREAM_PER_MINUTE=500
FORMS_BATCH_REQUEST_LIMIT=200
FORMS_WB_BATCH_SIZE=200
FORMS_WB_FLUSH_MS=300
FORMS_WB_MAX_QUEUE=10000
JWT_SECRET=replace_with_long_random_secret
AGENT_INGEST_TOKEN=replace_with_long_random_token
AGENT_STALE_AFTER_MS=120000
AGENT_STREAM_HEARTBEAT_MS=25000
AGENT_STREAM_BATCH_FLUSH_MS=120
TRACKING_WB_BATCH_SIZE=300
TRACKING_WB_FLUSH_MS=250
TRACKING_WB_MAX_QUEUE=10000
DB_POOL_MAX=30
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_SSL_MODE=auto
TRACKING_STREAM_KEY=tracking:events
TRACKING_STREAM_GROUP=tracking-workers
TRACKING_SEQ_HASH_KEY=tracking:last-seq
TRACKING_STREAM_MAX_LEN=200000
FORMS_STREAM_KEY=forms:events
FORMS_STREAM_GROUP=forms-workers
FORMS_STREAM_MAX_LEN=200000
FORMS_DEDUPE_PREFIX=forms:dedupe:
FORMS_DEDUPE_TTL_SEC=604800
STREAM_CONSUMER_BLOCK_MS=500
STREAM_CLAIM_IDLE_MS=30000
STREAM_CLAIM_BATCH_SIZE=200
STREAM_DLQ_MAX_ATTEMPTS=5
TRACKING_DLQ_STREAM_KEY=tracking:dlq
FORMS_DLQ_STREAM_KEY=forms:dlq

# PostgreSQL / PostGIS
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=replace_with_long_random_password
DATABASE_URL=postgresql://appuser:replace_with_long_random_password@postgres:5432/appdb

# Redis
REDIS_PASSWORD=replace_with_long_random_password
REDIS_URL=redis://:replace_with_long_random_password@redis:6379

# Backups
BACKUP_DIR=/srv/backups
BACKUP_RETENTION_DAYS=7
