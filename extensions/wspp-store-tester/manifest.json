{
  "manifest_version": 3,
  "name": "WSPP Goberna",
  "version": "10.1.0",
  "description": "Agente digital inteligente — detección, clasificación y validación — Goberna",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://api.goberna.us/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WSPP Goberna"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://web.whatsapp.com/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
