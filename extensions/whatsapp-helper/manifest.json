{
  "manifest_version": 3,
  "name": "WhatsApp Goberna Helper",
  "version": "1.2.0",
  "description": "Gestiona una sola pestaña de WhatsApp Web — no abre pestañas duplicadas",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://dashboard.grupogoberna.com/*",
        "https://*.vercel.app/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "js": ["dashboard-bridge.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
