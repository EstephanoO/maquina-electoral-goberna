{
  "manifest_version": 3,
  "name": "WhatsApp Goberna Helper",
  "version": "8.8.0",
  "description": "Una sola pestaña de WhatsApp Web — nunca abre duplicados. Integración con el dashboard de Goberna.",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://wa.me/*",
    "https://api.whatsapp.com/*",
    "https://dashboard.grupogoberna.com/*",
    "https://api.goberna.us/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://dashboard.grupogoberna.com/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["panel-app.js"],
      "css": ["panel-styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["panel-styles.css", "icons/*.png"],
      "matches": ["https://web.whatsapp.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
