# ══════════════════════════════════════════════════════════════════════
# GOBERNA — Root .gitignore
# ══════════════════════════════════════════════════════════════════════

# ── Secrets & Environment ───────────────────────────────────────────
.env
.env.local
**/.env.local
**/.env.*.local
CREDENCIALES.md
**/credentials/
!.env.example
!**/.env.example

# ── Runtime folders (VPS) ───────────────────────────────────────────
certbot/conf/
certbot/www/
.runtime/
logs/

# ── Agent/IDE tooling ───────────────────────────────────────────────
.agents/
.claude/
.cursor/
.idea/
*.swp
*.swo
*~

# ── Node ────────────────────────────────────────────────────────────
**/node_modules/
**/.turbo/
**/bun.lockb
*.tsbuildinfo

# ── Root phantom files (prevent accidental bun install from root) ──
/package.json
/bun.lock
/package-lock.json
/yarn.lock

# ── Build outputs ───────────────────────────────────────────────────
**/.next/
**/dist/
**/build/
**/.expo/
**/android/.gradle/
**/android/app/build/
**/ios/build/
**/ios/Pods/

# ── macOS ───────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Vercel ──────────────────────────────────────────────────────────
.vercel/
**/.vercel/

# ── Python ──────────────────────────────────────────────────────────
**/__pycache__/
*.pyc

# ── Local perf/test outputs ─────────────────────────────────────────
scripts/perf/*-latest.json
scripts/perf/matrix-*.json
scripts/perf/matrix-*.md
coverage/
**/.coverage/
*.lcov

# ── Logs ────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Uploads (user-generated files, not source code) ────────────────
/uploads/
/apps/*/uploads/
/srv/uploads/

# ── Mobile build artifacts ─────────────────────────────────────────
*.aab
*.ipa
*.apk

# ── Large GeoJSON (data already in PostGIS) ────────────────────────
geojsons/
apps/web/public/geo/departamentos*.geojson
apps/web/public/geo/provincias*.geojson
apps/web/public/geo/distritos*.geojson

# ── Security audits (NEVER commit) ──────────────────────────────────
SECURITY-AUDIT*.md

# ── Misc ────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.vercel
