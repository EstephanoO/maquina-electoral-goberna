{
  "expo": {
    "name": "Goberna Territorio",
    "slug": "goberna-territory-02",
    "version": "1.3.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/letter-g.png",
    "scheme": "com.estephano.gobernaterritory02",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.estephano.gobernaterritory02",
      "buildNumber": "3",
      "associatedDomains": [
        "applinks:electoral.goberna.club"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Goberna needs your location to record GPS coordinates when completing a field form. Your location data is not shared with third parties.",
        "NSCameraUsageDescription": "Goberna usa la cámara para adjuntar una foto al contacto de campo.",
        "NSPhotoLibraryUsageDescription": "Goberna accede a tus fotos solo para adjuntarlas a un contacto de campo.",
        "NSPhotoLibraryAddUsageDescription": "Goberna guarda fotos de contactos en tu galería.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        }
      }
    },
    "android": {
      "package": "com.estephano.gobernaterritory02",
      "versionCode": 3,
      "softwareKeyboardLayoutMode": "resize",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/letter-g.png",
        "backgroundColor": "#163960"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "electoral.goberna.club",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/letter-g.png"
    },
    "plugins": [
      "expo-router",
      "@maplibre/maplibre-react-native",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Goberna needs your location to record GPS coordinates when completing a field form. Your location data is not shared with third parties."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "usesCleartextTraffic": false,
            "extraGradleProperties": {
              "org.gradle.jvmargs": "-Xmx4g -XX:MaxMetaspaceSize=1g -Dkotlin.daemon.jvm.options=-Xmx2g"
            }
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/letter-g.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#163960",
          "dark": {
            "backgroundColor": "#163960"
          }
        }
      ],
      "expo-notifications",
      ["expo-image-picker", { "photosPermission": "Goberna accede a tus fotos solo para adjuntarlas a un contacto de campo." }]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "EXPO_PUBLIC_BACKEND_API_URL": "https://electoral.goberna.club/api",
      "EXPO_PUBLIC_AGENT_INGEST_TOKEN": "JPVK6a0xrV-FYVFWRgn_1ruofUhPcxkY5proTSBEmULYrActHJaU_8a99p2pf8Bq",
      "eas": {
        "projectId": "17429ec1-1da2-430f-9f52-efc82919c219"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/17429ec1-1da2-430f-9f52-efc82919c219",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    }
